# Server Configuration
PORT=4000
NODE_ENV=production

# Frontend URL (used for CORS, emails, and Stripe redirect URLs)
FRONTEND_URL=https://your-frontend-domain.com
CORS_ORIGINS=https://your-frontend-domain.com

# Database Connection
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://user:password@localhost:5432/findhandvaerkeren

# Authentication (JWT)
# IMPORTANT: Must be at least 32 characters in production
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Stripe Configuration & Keys
# Get these from your Stripe Dashboard -> Developers -> API Keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# Partner Plan Price IDs (from Stripe Dashboard -> Products)
STRIPE_PRICE_BASIC_MONTHLY=price_...
STRIPE_PRICE_BASIC_ANNUAL=price_...
STRIPE_PRICE_GOLD_MONTHLY=price_...
STRIPE_PRICE_GOLD_ANNUAL=price_...

# Marketing Services - Google Ads Price IDs
STRIPE_PRICE_ADS_BASIC=price_...
STRIPE_PRICE_ADS_STANDARD=price_...
STRIPE_PRICE_ADS_PRO=price_...

# Marketing Services - SEO Price IDs
STRIPE_PRICE_SEO_BASIC=price_...
STRIPE_PRICE_SEO_STANDARD=price_...
STRIPE_PRICE_SEO_PRO=price_...

# Optional: Tax Rate ID (from Stripe Dashboard -> Tax rates)
STRIPE_TAX_RATE_ID=txr_...

# Email Service (Resend)
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@yourdomain.com

# Error Tracking (Optional)
SENTRY_DSN=https://your-sentry-dsn@o0.ingest.sentry.io/0

# Uploads (Optional - for local file storage)
UPLOAD_DIR=uploads

# Logging (Optional)
LOG_LEVEL=info

# Admin login (production): after migrate deploy, run once from backend folder:
#   npx prisma db seed
# Seed creates ADMIN users (change passwords immediately in production):
#   admin@findhandvaerkeren.dk / superadmin@findhandvaerkeren.dk — see prisma/seed.ts
